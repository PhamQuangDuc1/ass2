@page
@model LoginModel
@{
    ViewData["Title"] = "Dang nhap";
}

<section class="auth-shell auth-shell-login">
    <div class="auth-panel">
        <span class="hero-badge"><i class="bi bi-mortarboard"></i> Smart Study Buddy</span>
        <h1>&#272;&#259;ng nh&#7853;p</h1>
        <p class="auth-intro">Ti&#7871;p t&#7909;c h&#7885;c v&#7899;i tr&#7907; l&#253; AI d&#7921;a tr&#234;n t&#224;i li&#7879;u m&#244;n h&#7885;c c&#7911;a b&#7841;n.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="notice notice-danger">@Model.ErrorMessage</div>
        }

        <form method="post" class="upload-form">
            <div class="form-row">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" autocomplete="username" autofocus />
            </div>
            <div class="form-row">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" autocomplete="current-password" />
            </div>
            <button type="submit" class="primary-action"><i class="bi bi-box-arrow-in-right"></i> &#272;&#259;ng nh&#7853;p</button>
        </form>

        <p class="auth-switch">Ch&#432;a c&#243; t&#224;i kho&#7843;n? <a asp-page="/Register">&#272;&#259;ng k&#253; h&#7885;c sinh</a></p>
    </div>

    <aside class="demo-panel">
        <div class="section-heading">
            <h2>T&#224;i kho&#7843;n demo</h2>
            <span>password: 123</span>
        </div>
        <div class="document-list">
            @foreach (var user in Model.DemoUsers)
            {
                <article class="document-item">
                    <strong>@user.Username</strong>
                    <span>@user.DisplayName - @user.Role</span>
                </article>
            }
        </div>
    </aside>
</section>
