@page
@model RegisterModel
@{
    ViewData["Title"] = "Dang ky";
}

<section class="auth-shell auth-shell-register">
    <div class="auth-panel">
        <span class="hero-badge"><i class="bi bi-person-plus"></i> T&#224;i kho&#7843;n m&#7899;i</span>
        <h1>&#272;&#259;ng k&#253; h&#7885;c sinh</h1>
        <p class="auth-intro">T&#7841;o t&#224;i kho&#7843;n &#273;&#7875; b&#7855;t &#273;&#7847;u h&#7887;i &#273;&#225;p v&#7899;i t&#224;i li&#7879;u h&#7885;c t&#7853;p b&#7857;ng Smart Study Buddy.</p>

        @if (!string.IsNullOrWhiteSpace(Model.RegisterErrorMessage))
        {
            <div class="notice notice-danger">@Model.RegisterErrorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.RegisterMessage))
        {
            <div class="notice notice-success">@Model.RegisterMessage</div>
        }

        <form method="post" class="upload-form">
            <div class="form-row">
                <label asp-for="RegisterDisplayName">T&#234;n hi&#7875;n th&#7883;</label>
                <input asp-for="RegisterDisplayName" autocomplete="name" />
            </div>
            <div class="form-row">
                <label asp-for="RegisterUsername">Username</label>
                <input asp-for="RegisterUsername" autocomplete="username" />
            </div>
            <div class="form-row">
                <label asp-for="RegisterPassword">Password</label>
                <input asp-for="RegisterPassword" type="password" autocomplete="new-password" />
            </div>
            <button type="submit" class="primary-action"><i class="bi bi-person-plus"></i> &#272;&#259;ng k&#253;</button>
        </form>

        <p class="auth-switch">&#272;&#227; c&#243; t&#224;i kho&#7843;n? <a asp-page="/Login">&#272;&#259;ng nh&#7853;p</a></p>
    </div>
</section>
