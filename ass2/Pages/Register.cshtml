@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-shell auth-shell-register">
    <div class="auth-panel">
        <span class="hero-badge"><i class="bi bi-person-plus"></i> Tài khoản mới</span>
        <h1>Đăng ký tài khoản</h1>
        <p class="auth-intro">Tạo tài khoản và chọn role để vào đúng trang làm việc.</p>

        @if (!string.IsNullOrWhiteSpace(Model.RegisterErrorMessage))
        {
            <div class="notice notice-danger">@Model.RegisterErrorMessage</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.RegisterMessage))
        {
            <div class="notice notice-success">@Model.RegisterMessage</div>
        }

        <form method="post" class="upload-form">
            <div class="form-row">
                <label asp-for="RegisterDisplayName">Tên hiển thị</label>
                <input asp-for="RegisterDisplayName" autocomplete="name" />
            </div>
            <div class="form-row">
                <label asp-for="RegisterUsername">Username</label>
                <input asp-for="RegisterUsername" autocomplete="username" />
            </div>
            <div class="form-row">
                <label asp-for="RegisterPassword">Password</label>
                <input asp-for="RegisterPassword" type="password" autocomplete="new-password" />
            </div>
            <div class="form-row">
                <label asp-for="RegisterRole">Role</label>
                <select asp-for="RegisterRole">
                    <option value="Student">Student</option>
                    <option value="Teacher">Teacher</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <div class="form-row">
                <label asp-for="RegisterManagedDepartment">Bộ môn giảng dạy nếu là Teacher</label>
                <select asp-for="RegisterManagedDepartment">
                    <option value="">Không chọn</option>
                    @foreach (var department in Model.DepartmentOptions)
                    {
                        <option value="@department">@department</option>
                    }
                </select>
            </div>
            <div class="form-row">
                <label asp-for="RegisterSubjects">Môn học giảng dạy nếu là Teacher</label>
                <select asp-for="RegisterSubjects" multiple size="5">
                    @foreach (var subject in Model.SubjectCatalog)
                    {
                        <option value="@subject.Name">@subject.Name (@subject.Department)</option>
                    }
                </select>
            </div>
            <button type="submit" class="primary-action"><i class="bi bi-person-plus"></i> Đăng ký</button>
        </form>

        <p class="auth-switch">Đã có tài khoản? <a asp-page="/Login">Đăng nhập</a></p>
    </div>
</section>
