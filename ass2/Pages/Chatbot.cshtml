@page
@using ass2.Components
@model ChatbotModel
@{
    ViewData["Title"] = "Chatbot";
}

<section class="app-workspace">
    <header class="workspace-header">
        <div>
            <p class="eyebrow">Smart Study Buddy</p>
            <h1>AI học tập theo tài liệu môn học</h1>
        </div>
        <div class="user-card">
            <strong>@Model.CurrentUserName</strong>
            <span>
                @Model.CurrentRole
                @if (Model.CurrentRole == "Teacher" && !string.IsNullOrWhiteSpace(Model.CurrentManagedDepartment))
                {
                    <text> - Bo mon @Model.CurrentManagedDepartment</text>
                }
            </span>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice notice-success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="notice notice-danger">@Model.ErrorMessage</div>
    }

    <nav class="feature-tabs" aria-label="Chuc nang">
        <a class="tab-button @(Model.ActiveTab == "chatTab" ? "active" : "")" asp-page="/Chatbot" asp-route-ActiveTab="chatTab">Chat</a>
        <a class="tab-button @(Model.ActiveTab == "documentsTab" ? "active" : "")" asp-page="/Chatbot" asp-route-ActiveTab="documentsTab">Tai lieu</a>
        @if (Model.CanSeeUploadTab)
        {
            <a class="tab-button @(Model.ActiveTab == "editDocumentsTab" ? "active" : "")" asp-page="/Chatbot" asp-route-ActiveTab="editDocumentsTab">Chỉnh sửa sau</a>
        }
        @if (Model.CurrentRole == "Admin")
        {
            <a class="tab-button @(Model.ActiveTab == "adminTab" ? "active" : "")" asp-page="/Chatbot" asp-route-ActiveTab="adminTab">Admin</a>
            <a class="tab-button @(Model.ActiveTab == "subjectsTab" ? "active" : "")" asp-page="/Chatbot" asp-route-ActiveTab="subjectsTab">Mon hoc</a>
        }
        <a class="tab-button @(Model.ActiveTab == "benchmarkTab" ? "active" : "")" asp-page="/Chatbot" asp-route-ActiveTab="benchmarkTab">Benchmark</a>
    </nav>

    <section class="tab-panel @(Model.ActiveTab == "chatTab" ? "active" : "")" id="chatTab" hidden="@(Model.ActiveTab != "chatTab")">
        <component type="typeof(BlazorSignalRChat)" render-mode="ServerPrerendered" param-ShowHeader="false" />
    </section>

    <section class="tab-panel @(Model.ActiveTab == "documentsTab" ? "active" : "")" id="documentsTab" hidden="@(Model.ActiveTab != "documentsTab")">
        <div class="tab-heading">
            <div>
                <p class="eyebrow">Quan ly tai lieu</p>
                <h2>Danh sach tai lieu da index</h2>
            </div>
            <span class="session-chip"><span id="visibleDocumentCount">@Model.Documents.Count</span>/<span id="totalDocumentCount">@Model.Documents.Count</span> tai lieu</span>
        </div>

        <component type="typeof(RealtimeDocuments)" render-mode="ServerPrerendered" param-AllowedSubjects="Model.VisibleSubjectOptions" />
    </section>

    @if (Model.CanSeeUploadTab)
    {
        <section class="tab-panel @(Model.ActiveTab == "editDocumentsTab" ? "active" : "")" id="editDocumentsTab" hidden="@(Model.ActiveTab != "editDocumentsTab")">
            <div class="tab-heading">
                <div>
                    <p class="eyebrow">Upload & Index</p>
                    <h2>Them tai lieu vao kho</h2>
                </div>
            </div>

            <div class="role-policy">
                <strong>Quyen tai lieu cua ban</strong>
                <span>
                    <text>Teacher duoc upload tai lieu cho mon hoc da duoc Admin gan.</text>
                </span>
            </div>

            @if (Model.UploadSubjectOptions.Count == 0)
            {
                <div class="notice notice-danger">Tai khoan Teacher nay chua duoc gan mon hoc nen chua the upload tai lieu.</div>
            }
            else
            {
                <form class="upload-form upload-form-wide" method="post" enctype="multipart/form-data" asp-page-handler="Upload">
                <div class="form-grid">
                    <div class="form-row">
                        <label asp-for="Department">Bo mon</label>
                        <input asp-for="Department" readonly />
                    </div>
                    <div class="form-row">
                        <label asp-for="Subject">Mon hoc</label>
                        <select asp-for="Subject">
                            @foreach (var subject in Model.UploadSubjectOptions)
                            {
                                <option value="@subject">@subject</option>
                            }
                        </select>
                    </div>
                    <div class="form-row">
                        <label asp-for="Chapter">Chuong</label>
                        <input asp-for="Chapter" />
                    </div>
                    <div class="form-row">
                        <label asp-for="Teacher">Giang vien</label>
                        <input asp-for="Teacher" readonly />
                    </div>
                </div>

                <div class="form-row">
                    <label asp-for="Title">Ten tai lieu</label>
                    <input asp-for="Title" placeholder="VD: Slide Razor Pages Chapter 2" />
                </div>

                <div class="form-row">
                    <label asp-for="UploadFile">PDF, DOCX, PPTX, TXT</label>
                    <input asp-for="UploadFile" type="file" accept=".pdf,.docx,.pptx,.txt,.md,.csv" />
                </div>

                <div class="form-row">
                    <label asp-for="ManualContent">Noi dung/tom tat de index</label>
                    <textarea asp-for="ManualContent" rows="6" placeholder="Nhap noi dung chinh cua tai lieu de chatbot tra loi chinh xac hon."></textarea>
                </div>

                <button type="submit" class="primary-action">Upload & index</button>
                </form>
            }

            <section class="teacher-document-actions">
                <div class="tab-heading">
                    <div>
                        <p class="eyebrow">Tai lieu cua ban</p>
                        <h3>Sua, xoa, re-index tai lieu</h3>
                    </div>
                    <span class="session-chip">@Model.Documents.Count(Model.CanManageDocument) tai lieu</span>
                </div>

                <div class="document-list document-list-wide">
                    @foreach (var document in Model.Documents.Where(Model.CanManageDocument))
                    {
                        <article class="document-item">
                            <div class="document-header">
                                <strong>@document.Title</strong>
                                <span class="department-badge">@document.Subject / @document.Chapter</span>
                            </div>
                            <form class="document-edit-form" method="post" enctype="multipart/form-data" asp-page-handler="UpdateDocument">
                                <input type="hidden" name="DocumentId" value="@document.Id" />
                                <div class="form-grid">
                                    <div class="form-row">
                                        <label for="title-@document.Id">Ten tai lieu</label>
                                        <input id="title-@document.Id" name="Title" value="@document.Title" />
                                    </div>
                                    <div class="form-row">
                                        <label for="subject-@document.Id">Mon hoc</label>
                                        <select id="subject-@document.Id" name="Subject">
                                            @foreach (var subject in Model.UploadSubjectOptions)
                                            {
                                                <option value="@subject" selected="@(string.Equals(document.Subject, subject, StringComparison.OrdinalIgnoreCase))">@subject</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-row">
                                        <label for="chapter-@document.Id">Chuong</label>
                                        <input id="chapter-@document.Id" name="Chapter" value="@document.Chapter" />
                                    </div>
                                    <div class="form-row">
                                        <label for="file-@document.Id">File moi neu can</label>
                                        <input id="file-@document.Id" name="UploadFile" type="file" accept=".pdf,.docx,.pptx,.txt,.md,.csv" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label for="content-@document.Id">Noi dung index</label>
                                    <textarea id="content-@document.Id" name="ManualContent" rows="4">@document.Content</textarea>
                                </div>
                                <div class="tab-actions">
                                    <button type="submit" class="secondary-action">Sua thong tin tai lieu</button>
                                </div>
                            </form>
                            <div class="document-actions-row">
                                <form method="post" asp-page-handler="ReindexDocument">
                                    <input type="hidden" name="DocumentId" value="@document.Id" />
                                    <button type="submit" class="secondary-action">Cap nhat/Re-index tai lieu</button>
                                </form>
                                <form method="post" asp-page-handler="DeleteDocument">
                                    <input type="hidden" name="DocumentId" value="@document.Id" />
                                    <button type="submit" class="secondary-action danger-action">Xoa tai lieu</button>
                                </form>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </section>
    }

    @if (Model.CurrentRole == "Admin")
    {
        <section class="tab-panel @(Model.ActiveTab == "adminTab" ? "active" : "")" id="adminTab" hidden="@(Model.ActiveTab != "adminTab")">
            <div class="tab-heading">
                <div>
                    <p class="eyebrow">Admin</p>
                    <h2>Set role tai khoan va chunk</h2>
                </div>
                <span class="session-chip">@Model.Users.Count tai khoan</span>
            </div>

            <div class="admin-tools">
                <form method="post" asp-page-handler="UpdateChunkSettings" class="role-update-form">
                    <div class="form-row">
                        <label asp-for="ChunkSize">Chunk size</label>
                        <input asp-for="ChunkSize" type="number" min="200" max="8000" />
                    </div>
                    <div class="form-row">
                        <label asp-for="ChunkOverlap">Chunk overlap</label>
                        <input asp-for="ChunkOverlap" type="number" min="0" max="7999" />
                    </div>
                    <button type="submit" class="secondary-action">Cap nhat chunk</button>
                </form>
            </div>

            <div class="document-list document-list-wide">
                @foreach (var user in Model.Users)
                {
                    <article class="document-item">
                        <div class="document-header">
                            <strong>@user.Username</strong>
                            <span class="department-badge">@user.Role</span>
                        </div>
                        <div class="document-meta">
                            <span>@user.DisplayName</span>
                            <span>Bo mon giang day: @(user.Role == "Teacher" && !string.IsNullOrWhiteSpace(user.ManagedDepartment) ? user.ManagedDepartment : "Khong")</span>
                            <span>Mon duoc gan: @(Model.GetAssignedSubjects(user.Username).Count > 0 ? string.Join(", ", Model.GetAssignedSubjects(user.Username)) : "Chua co")</span>
                        </div>
                        <form method="post" asp-page-handler="UpdateRole" class="role-update-form">
                            <input type="hidden" name="RoleUsername" value="@user.Username" />
                            <div class="form-row">
                                <label for="role-@user.Username">Role</label>
                                <select id="role-@user.Username" name="Role">
                                    <option value="Student" selected="@(user.Role == "Student")">Student</option>
                                    <option value="Teacher" selected="@(user.Role == "Teacher")">Teacher</option>
                                    <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                                </select>
                            </div>
                            @if (user.Role == "Teacher")
                            {
                                <div class="form-row">
                                    <label for="department-@user.Username">Bo mon giang day</label>
                                    <select id="department-@user.Username" name="ManagedDepartment">
                                        <option value="">Chon bo mon</option>
                                        @foreach (var department in Model.DepartmentOptions)
                                        {
                                            <option value="@department" selected="@(string.Equals(user.ManagedDepartment, department, StringComparison.OrdinalIgnoreCase))">@department</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-row">
                                    <label for="subject-@user.Username">Mon hoc giang day</label>
                                    <select id="subject-@user.Username" name="AssignSubjects" multiple size="5">
                                        @foreach (var subject in Model.SubjectCatalog)
                                        {
                                            var assignedToThisTeacher = Model.GetAssignedSubjects(user.Username).Contains(subject.Name, StringComparer.OrdinalIgnoreCase);
                                            <option value="@subject.Name" selected="@assignedToThisTeacher">
                                                @subject.Name (@subject.Department)
                                            </option>
                                        }
                                    </select>
                                </div>
                            }
                            <button type="submit" class="secondary-action">Cap nhat</button>
                        </form>
                    </article>
                }
            </div>
        </section>

        <section class="tab-panel @(Model.ActiveTab == "subjectsTab" ? "active" : "")" id="subjectsTab" hidden="@(Model.ActiveTab != "subjectsTab")">
            <div class="tab-heading">
                <div>
                    <p class="eyebrow">Mon hoc</p>
                    <h2>Quan ly mon hoc va giao vien</h2>
                </div>
                <span class="session-chip">@Model.SubjectOptions.Count mon hoc</span>
            </div>

            <div class="admin-tools">
                <form method="post" asp-page-handler="CreateSubject" class="role-update-form">
                    <div class="form-row">
                        <label asp-for="NewDepartment">Bo mon</label>
                        <input asp-for="NewDepartment" placeholder="VD: PRN222" />
                    </div>
                    <div class="form-row">
                        <label asp-for="NewSubject">Mon hoc moi</label>
                        <input asp-for="NewSubject" placeholder="VD: Entity Framework" />
                    </div>
                    <button type="submit" class="secondary-action">Tao mon</button>
                </form>
            </div>

            <div class="subject-chapter-summary">
                @foreach (var subject in Model.SubjectOptions)
                {
                    <span>@subject (@Model.SubjectCatalog.FirstOrDefault(item => item.Name == subject)?.Department) - @Model.GetSubjectOwnerLabel(subject)</span>
                }
            </div>
        </section>
    }

    <section class="tab-panel @(Model.ActiveTab == "benchmarkTab" ? "active" : "")" id="benchmarkTab" hidden="@(Model.ActiveTab != "benchmarkTab")">
        <div class="tab-heading">
            <div>
                <p class="eyebrow">RAG benchmark</p>
                <h2>So sanh model demo</h2>
            </div>
            <span class="session-chip">Du lieu thuc nghiem</span>
        </div>

        <form method="post" asp-page-handler="RunBenchmark">
            <button type="submit" class="primary-action">Chay benchmark</button>
        </form>

        @if (Model.BenchmarkResults is null)
        {
            <p>Chay benchmark de do tren tai lieu hien co. Provider chua co API key se duoc danh dau, khong dung so lieu gia.</p>
        }
        else
        {
            <h3>Chunking strategy</h3>
            <table class="benchmark-table">
                <thead><tr><th>Strategy</th><th>P@@3</th><th>R@@3</th><th>MRR</th><th>Latency</th></tr></thead>
                <tbody>
                @foreach (var result in Model.BenchmarkResults.ChunkingResults)
                {
                    <tr><td>@result.Name</td><td>@result.PrecisionAt3.ToString("0.000")</td><td>@result.RecallAt3.ToString("0.000")</td><td>@result.MeanReciprocalRank.ToString("0.000")</td><td>@result.AverageLatencyMs.ToString("0.0") ms</td></tr>
                }
                </tbody>
            </table>

            <h3>Embedding model</h3>
            <table class="benchmark-table">
                <thead><tr><th>Model</th><th>Status</th><th>P@@3</th><th>R@@3</th><th>MRR</th><th>Latency</th><th>Ghi chu</th></tr></thead>
                <tbody>
                @foreach (var result in Model.BenchmarkResults.EmbeddingResults)
                {
                    <tr><td>@result.Name</td><td>@result.Status</td><td>@result.PrecisionAt3.ToString("0.000")</td><td>@result.RecallAt3.ToString("0.000")</td><td>@result.MeanReciprocalRank.ToString("0.000")</td><td>@result.AverageLatencyMs.ToString("0.0") ms</td><td>@result.Note</td></tr>
                }
                </tbody>
            </table>

            <h3>RAG vs fine-tuned model</h3>
            <table class="benchmark-table">
                <thead><tr><th>Approach</th><th>Status</th><th>Document coverage</th><th>Latency</th><th>Ghi chu</th></tr></thead>
                <tbody>
                @foreach (var result in Model.BenchmarkResults.GenerationResults)
                {
                    <tr><td>@result.Approach</td><td>@result.Status</td><td>@result.DocumentCoverage.ToString("0.000")</td><td>@result.AverageLatencyMs.ToString("0.0") ms</td><td>@result.Note</td></tr>
                }
                </tbody>
            </table>
        }

        <div class="subject-summary">
            @foreach (var subject in Model.SubjectCounts)
            {
                <span>@subject.Key: @subject.Value</span>
            }
        </div>
    </section>
</section>

<script src="_framework/blazor.server.js"></script>
