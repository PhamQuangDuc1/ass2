@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = User.Identity?.Name ?? "User";
    var currentRole = User.FindFirstValue(ClaimTypes.Role) ?? "Student";
    var workspaceLabel = currentRole switch
    {
        "Admin" => "Trang quan tri",
        "Teacher" => "Trang giang vien",
        _ => "Trang hoc sinh"
    };
    var initials = string.Join("", displayName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(part => part[0]))
        .ToUpperInvariant();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Study Buddy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ass2.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-navbar fixed-top">
            <div class="container">
                @if (isAuthenticated)
                {
                    <a class="navbar-brand" asp-area="" asp-page="/Chatbot"><i class="bi bi-mortarboard-fill"></i> Smart Study Buddy</a>
                }
                else
                {
                    <a class="navbar-brand" asp-area="" asp-page="/Index"><i class="bi bi-mortarboard-fill"></i> Smart Study Buddy</a>
                }
                <div class="navbar-collapse app-navbar-static" id="mainNavbar">
                    @if (!isAuthenticated)
                    {
                        <ul class="navbar-nav mx-auto">
                            <li class="nav-item">
                                <a class="nav-link" href="/#home">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/#features">Features</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/#about">About</a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <div class="app-nav-status mx-auto">
                            <span>@workspaceLabel</span>
                        </div>
                    }

                    <div class="auth-nav">
                        @if (isAuthenticated)
                        {
                            <div class="account-menu account-menu-static">
                                <div class="avatar-button">
                                    <span class="avatar-circle">@initials</span>
                                    <span class="avatar-meta">
                                        <strong>@displayName</strong>
                                        <small>@currentRole</small>
                                    </span>
                                </div>
                                <a class="account-link" asp-page="/Chatbot">
                                    Chatbot AI
                                </a>
                                <a class="account-link" asp-page="/BlazorChat">
                                    Blazor SignalR
                                </a>
                                <form method="post" asp-page="/Logout" class="dropdown-logout-form">
                                    <button type="submit" class="account-link logout-item">
                                        &#272;&#259;ng xu&#7845;t
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <a class="nav-link" asp-page="/Login">&#272;&#259;ng nh&#7853;p</a>
                            <a class="btn btn-primary nav-register" asp-page="/Register">&#272;&#259;ng k&#253;</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="app-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    @if (!isAuthenticated)
    {
        <footer class="footer text-muted">
            <div class="container footer-inner">
                <strong>Smart Study Buddy</strong>
                <span>Copyright 2026</span>
            </div>
        </footer>
    }

</body>
</html>
